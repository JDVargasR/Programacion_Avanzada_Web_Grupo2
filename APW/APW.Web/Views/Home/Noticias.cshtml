@model APW.Web.Models.NoticiasViewModel
@{
    ViewBag.Title = "Noticias";
    var esAdmin = Context.Session.GetInt32("RolId") == 1;
}

<main class="news-page">
    <section class="news-hero">
        <div class="lp-container news-hero__inner">
            <div>
                <div class="news-kicker">Dashboard</div>
                <h1>Noticias</h1>
                <p class="news-sub">Panel editorial con las últimas publicaciones, etiquetas y estados.</p>
            </div>
        </div>
    </section>

    @if (esAdmin)
    {
        @* ── ANÁLISIS CON IA ── *@
        <section class="lp-container news-ai-upload-wrap">
            <div class="news-ai-upload">
                <h3 class="news-ai-upload__title">
                    Analizá una noticia con IA
                </h3>
                <p class="news-ai-upload__text">
                    Subí una noticia y la IA identifica el género, y te crea un resumen automático.
                </p>
                <form method="post" action="/ExportImport/Upload" enctype="multipart/form-data"
                      class="news-ai-upload__form">
                    <input type="file" name="file" accept=".json" class="news-ai-upload__input" />
                    <button type="submit" class="news-btn news-btn--primary">Analizar noticia</button>
                </form>
            </div>
        </section>
    }

    @* ── PANEL DE IA ── *@
    @{
        var aiSummary     = Context.Session.GetString("AiSummary");
        var aiSentiment   = Context.Session.GetString("AiSentiment");
        var aiReadingTime = Context.Session.GetString("AiReadingTime");
        var aiKeywords    = Context.Session.GetString("AiKeywords");
        var aiTitle       = Context.Session.GetString("AiTitle");
    }

    @if (esAdmin && !string.IsNullOrEmpty(aiSummary))
    {
        <section class="lp-container news-ai-result-wrap">
            <div class="news-ai-result">
                <div class="news-ai-result__header">
                    <div class="news-ai-result__dot"></div>
                    <span class="news-ai-result__label">
                        Análisis generado por IA — Claude Haiku
                    </span>
                </div>
                @if (!string.IsNullOrEmpty(aiTitle))
                {
                    <p class="news-ai-result__title">
                        @aiTitle
                    </p>
                }
                <p class="news-ai-result__summary">
                    @aiSummary
                </p>
                <div class="news-ai-result__meta">
                    <span>Sentimiento: <strong>@aiSentiment</strong></span>
                    <span>Lectura estimada: <strong>@aiReadingTime min</strong></span>
                </div>
                @if (!string.IsNullOrEmpty(aiKeywords))
                {
                    <div class="news-ai-result__keywords">
                        @foreach (var kw in aiKeywords.Split(','))
                        {
                            <span class="news-ai-result__keyword">
                                @kw.Trim()
                            </span>
                        }
                    </div>
                }
            </div>
        </section>
    }

    <section class="news-shell lp-container">
        <aside class="news-sidebar" aria-label="Resumen de noticias">
            <div class="news-sidebar__title">Resumen</div>
            <div class="news-sideitem">
                Importadas
                <span class="news-sideitem__value">@Model.ImportedItems.Count</span>
            </div>
            <div class="news-sideitem">
                Fijadas
                <span class="news-sideitem__value">@Model.PinnedItems.Count</span>
            </div>
            <div class="news-sideitem">
                En vivo
                <span class="news-sideitem__value">@Model.LiveItems.Count</span>
            </div>
            <div class="news-sideitem">
                Total
                <span class="news-sideitem__value">@Model.AllItems.Count()</span>
            </div>
        </aside>

        <div class="news-main">
            @if (!Model.AllItems.Any())
            {
                <p style="color:#888;padding:2rem 0;text-align:center">
                    No hay noticias disponibles. Importá un JSON o configurá la API de noticias.
                </p>
            }

            @* ── IMPORTADAS ── *@
            @if (Model.ImportedItems.Any())
            {
                <div style="font-size:12px;font-weight:600;color:#534AB7;margin:1rem 0 0.5rem;text-transform:uppercase;letter-spacing:.05em">
                    Importadas
                </div>
                <div class="news-grid">
                    @foreach (var item in Model.ImportedItems)
                    {
                        <article class="news-card">
                            <div class="news-card__meta">
                                <span class="news-tag">@(string.IsNullOrEmpty(item.Category) ? "General" : item.Category)</span>
                                <span class="news-date">@item.PublishedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            <h3>@item.Title</h3>
                            <p class="news-preview">@item.Summary</p>
                            <div class="news-card__actions">
                                @if (esAdmin && item.LocalId.HasValue)
                                {
                                    <a href="/ExportImport/Download/@item.LocalId" class="news-btn news-btn--ghost">Descargar</a>
                                }
                                <span style="font-size:11px;color:#888;align-self:center">
                                    📥 @item.SourceName
                                </span>
                            </div>
                        </article>
                    }
                </div>
            }

            @* ── FIJADAS ── *@
            @if (Model.PinnedItems.Any())
            {
                <div style="font-size:12px;font-weight:600;color:#534AB7;margin:1.5rem 0 0.5rem;text-transform:uppercase;letter-spacing:.05em">
                    Fijadas
                </div>
                <div class="news-grid">
                    @foreach (var item in Model.PinnedItems)
                    {
                        <article class="news-card">
                            <div class="news-card__meta">
                                <span class="news-tag">@(string.IsNullOrEmpty(item.Category) ? "General" : item.Category)</span>
                                <span class="news-date">@item.PublishedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            <h3>@item.Title</h3>
                            <p class="news-preview">@item.Summary</p>
                            <div class="news-card__actions">
                                @if (esAdmin && item.LocalId.HasValue)
                                {
                                    <a href="/ExportImport/Download/@item.LocalId" class="news-btn news-btn--ghost">Descargar</a>
                                }
                                @if (!string.IsNullOrEmpty(item.Url))
                                {
                                    <a href="@item.Url" target="_blank" class="news-btn news-btn--ghost">Ver artículo</a>
                                }
                                <span style="font-size:11px;color:#888;align-self:center">📌 Fijado</span>
                            </div>
                        </article>
                    }
                </div>
            }

            @* ── EN VIVO ── *@
            @if (Model.LiveItems.Any())
            {
                <div style="font-size:12px;font-weight:600;color:#534AB7;margin:1.5rem 0 0.5rem;text-transform:uppercase;letter-spacing:.05em">
                    En vivo
                </div>
                <div class="news-grid">
                    @foreach (var item in Model.LiveItems)
                    {
                        <article class="news-card">
                            <div class="news-card__meta">
                                <span class="news-tag">@(string.IsNullOrEmpty(item.Category) ? item.SourceName : item.Category)</span>
                                <span class="news-date">@item.PublishedAt.ToString("dd MMM yyyy")</span>
                            </div>
                            <h3>@item.Title</h3>
                            <p class="news-preview">@item.Summary</p>
                            <div class="news-card__actions">
                                @if (!string.IsNullOrEmpty(item.Url))
                                {
                                    <a href="@item.Url" target="_blank" class="news-btn news-btn--ghost">Ver artículo</a>
                                }
                                @if (esAdmin)
                                {
                                    <form method="post" action="/Home/Pin" style="display:contents">
                                        <input type="hidden" name="externalId"  value="@item.ExternalId" />
                                        <input type="hidden" name="title"       value="@item.Title" />
                                        <input type="hidden" name="summary"     value="@item.Summary" />
                                        <input type="hidden" name="url"         value="@item.Url" />
                                        <input type="hidden" name="author"      value="@item.Author" />
                                        <input type="hidden" name="sourceName"  value="@item.SourceName" />
                                        <button type="submit" class="news-btn news-btn--primary">Fijar</button>
                                    </form>
                                }
                            </div>
                        </article>
                    }
                </div>
            }

        </div>
    </section>
</main>
